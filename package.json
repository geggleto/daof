{
  "name": "@geggleto/daof",
  "version": "0.1.0",
  "description": "Declarative Agentic Orchestration Framework",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "daof": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:unit": "vitest run -c vitest.unit.config.ts",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "validate": "node dist/cli/index.js validate org.example.yaml",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "keywords": [
    "daof",
    "agents",
    "orchestration",
    "yaml",
    "llm",
    "workflow",
    "autonomous"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/geggleto/daof"
  },
  "homepage": "https://github.com/geggleto/daof#readme",
  "bugs": {
    "url": "https://github.com/geggleto/daof/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@langchain/core": "^1.1.31",
    "@langchain/langgraph": "^1.2.2",
    "commander": "^12.1.0",
    "cron-parser": "^5.5.0",
    "dotenv": "^16.4.5",
    "ioredis": "^5.10.0",
    "mongodb": "^6.12.0",
    "marked": "^17.0.4",
    "node-cron": "^4.2.1",
    "ora": "^9.3.0",
    "p-circuit-breaker": "^0.0.3",
    "twitter-api-v2": "^1.29.0",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.7.2",
    "vitest": "^2.1.6"
  },
  "files": [
    "dist"
  ]
}
